

server:
  exchangeManager:
    name: "filesystem"
    baseDir:
      - "s3://bucket-name"
additionalExchangeManagerProperties:
  - exchange.s3.region=us-east-1
  - exchange.s3.endpoint=
  - exchange.s3.aws-access-key=
  - exchange.s3.aws-secret-key=

additionalConfigProperties:
  - http-server.process-forwarded=IGNORE

catalogs:
  objectstore: |
    connector.name=iceberg
    iceberg.catalog.type=rest

ingress:
  enabled: true
  className: "nginx"
  annotations: {}
  hosts:
    - host: custom.lab.incubateur.finances.rie.gouv.fr
      paths:
        - path: /
          pathType: ImplementationSpecific
